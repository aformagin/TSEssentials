$Common = "Common.ui";

Group {
  LayoutMode: Center;

  Group #ChatEditPanel {
    Anchor: (Width: 920, Height: 720);
    LayoutMode: Top;
    Padding: (Full: 32);

    Label #Title {
      Style: (FontSize: 34, Alignment: Center);
      Anchor: (Top: 24);
      Text: "TSChat Channels";
      Padding: (Full: 10);
    }

    Label #Subtitle {
      Style: (FontSize: 18, Alignment: Center);
      Anchor: (Top: 8);
      Text: "Configured channels and edit commands";
      Padding: (Full: 10);
    }

    Label #ChannelList {
      Style: (FontSize: 20, HorizontalAlignment: Start);
      Anchor: (Top: 28, Width: 840, Height: 430);
      Text: "";
      Padding: (Full: 12);
    }

    Label #CommandTitle {
      Style: (FontSize: 22, HorizontalAlignment: Start);
      Anchor: (Top: 20);
      Text: "Commands";
      Padding: (Full: 8);
    }

    Label #CommandHelp {
      Style: (FontSize: 18, HorizontalAlignment: Start);
      Anchor: (Top: 8, Width: 840, Height: 80);
      Text: "";
      Padding: (Full: 8);
    }
  }
}
