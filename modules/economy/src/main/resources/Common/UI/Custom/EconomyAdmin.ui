$C = "Common.ui";

@FieldLabel = Label {
  Anchor: (Bottom: 4);
  Style: (FontSize: 12, RenderBold: true, RenderUppercase: true, TextColor: #bbbbbb);
};

@SectionTitle = Label {
  Anchor: (Height: 26, Bottom: 8);
  Style: (FontSize: 14, RenderBold: true, RenderUppercase: true, TextColor: #f1ba50, VerticalAlignment: Center);
};

Group {
  Background: #000000(0.35);
  LayoutMode: Middle;

  Group #EconomyAdminPanel {
    Anchor: (Width: 1120, Height: 720);
    Background: #111111(0.86);
    OutlineSize: 1;
    OutlineColor: #ffffff(0.18);
    LayoutMode: Top;
    Padding: (Full: 2);

    Group #Header {
      Anchor: (Height: 58, Bottom: 1);
      Background: #343434(0.92);
      LayoutMode: Left;
      Padding: (Horizontal: 18);

      Label #Title {
        FlexWeight: 1;
        Style: (FontSize: 24, RenderBold: true, TextColor: #ffffff, VerticalAlignment: Center);
        Text: "TSEconomy Admin";
      }

      Label #StatusMessage {
        Anchor: (Width: 410, Height: 34);
        Padding: (Horizontal: 10);
        Visible: false;
        Style: (FontSize: 13, RenderBold: true, TextColor: #bdf2c3, VerticalAlignment: Center, Wrap: true);
      }
    }

    Group #Body {
      FlexWeight: 1;
      LayoutMode: Left;

      Group #LeftPane {
        Anchor: (Width: 360);
        Background: #252525(0.92);
        LayoutMode: Top;
        Padding: (Full: 14);

        @SectionTitle { Text: "Known Accounts"; }

        Group #AccountList {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Right: 6);

          $C.@TextButton #AccountRow0 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow1 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow2 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow3 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow4 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow5 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow6 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow7 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow8 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #AccountRow9 { @Anchor = (Height: 38, Bottom: 5); Text: ""; Visible: false; }
        }
      }

      Group #RightPane {
        FlexWeight: 1;
        Background: #414141(0.92);
        LayoutMode: Top;
        Padding: (Full: 22);

        Label #SelectedTitle {
          Anchor: (Height: 38, Bottom: 8);
          Style: (FontSize: 24, RenderBold: true, TextColor: #ffffff, VerticalAlignment: Center);
          Text: "No account selected";
        }

        Label #CurrentBalance {
          Anchor: (Height: 28, Bottom: 18);
          Style: (FontSize: 15, TextColor: #8de969, VerticalAlignment: Center);
          Text: "";
        }

        Group #Form {
          LayoutMode: Top;
          FlexWeight: 1;
          Padding: (Right: 10);

          @FieldLabel { Text: "Player or UUID"; }
          $C.@TextField #TargetInput { @Anchor = (Height: 38, Bottom: 12); }

          @FieldLabel { Text: "Action"; }
          $C.@DropdownBox #ActionDropdown {
            @Anchor = (Height: 38, Bottom: 12);
            ShowSearchInput: false;
            MaxSelection: 1;
          }

          @FieldLabel { Text: "Amount"; }
          $C.@TextField #AmountInput { @Anchor = (Height: 38, Bottom: 12); }
        }

        Group #Actions {
          Anchor: (Height: 46, Top: 16);
          LayoutMode: Right;

          $C.@TextButton #ApplyButton {
            @Anchor = (Width: 150);
            Text: "Apply";
          }
        }
      }
    }
  }
}
