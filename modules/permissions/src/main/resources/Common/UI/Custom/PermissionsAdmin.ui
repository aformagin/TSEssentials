$C = "Common.ui";

@FieldLabel = Label {
  Anchor: (Bottom: 4);
  Style: (FontSize: 12, RenderBold: true, RenderUppercase: true, TextColor: #bbbbbb);
};

@SectionTitle = Label {
  Anchor: (Height: 24, Bottom: 7);
  Style: (FontSize: 13, RenderBold: true, RenderUppercase: true, TextColor: #f1ba50, VerticalAlignment: Center);
};

Group {
  Background: #000000(0.35);
  LayoutMode: Middle;

  Group #PermissionsAdminPanel {
    Anchor: (Width: 1160, Height: 760);
    Background: #111111(0.86);
    OutlineSize: 1;
    OutlineColor: #ffffff(0.18);
    LayoutMode: Top;
    Padding: (Full: 2);

    Group #Header {
      Anchor: (Height: 58, Bottom: 1);
      Background: #343434(0.92);
      LayoutMode: Left;
      Padding: (Horizontal: 18);

      Label #Title {
        FlexWeight: 1;
        Style: (FontSize: 24, RenderBold: true, TextColor: #ffffff, VerticalAlignment: Center);
        Text: "TSE Permissions";
      }

      Label #StatusMessage {
        Anchor: (Width: 460, Height: 34);
        Padding: (Horizontal: 10);
        Visible: false;
        Style: (FontSize: 13, RenderBold: true, TextColor: #bdf2c3, VerticalAlignment: Center, Wrap: true);
      }
    }

    Group #Body {
      FlexWeight: 1;
      LayoutMode: Left;

      Group #LeftPane {
        Anchor: (Width: 340);
        Background: #252525(0.92);
        LayoutMode: Top;
        Padding: (Full: 14);

        @SectionTitle { Text: "Groups"; }

        Group #GroupList {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Right: 6);

          $C.@TextButton #GroupRow0 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow1 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow2 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow3 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow4 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow5 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow6 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow7 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow8 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
          $C.@TextButton #GroupRow9 { @Anchor = (Height: 36, Bottom: 5); Text: ""; Visible: false; }
        }

        @FieldLabel { Text: "Group Name"; }
        $C.@TextField #GroupNameInput { @Anchor = (Height: 36, Bottom: 8); }

        @FieldLabel { Text: "Display Name"; }
        $C.@TextField #DisplayNameInput { @Anchor = (Height: 36, Bottom: 10); }

        $C.@TextButton #CreateGroupButton {
          @Anchor = (Height: 38);
          Text: "+ Add Group";
        }
      }

      Group #RightPane {
        FlexWeight: 1;
        Background: #414141(0.92);
        LayoutMode: Top;
        Padding: (Full: 20);

        Label #SelectedTitle {
          Anchor: (Height: 36, Bottom: 10);
          Style: (FontSize: 24, RenderBold: true, TextColor: #ffffff, VerticalAlignment: Center);
          Text: "No group selected";
        }

        Group #Columns {
          FlexWeight: 1;
          LayoutMode: Left;

          Group #NodePane {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Right: 12);

            @SectionTitle { Text: "Permission Nodes"; }
            Group #NodeInputStack {
              Anchor: (Width: 380, Height: 80, Bottom: 8);

              $C.@DropdownBox #KnownNodeDropdown { @Anchor = (Left: 0, Top: 0, Width: 380, Height: 36); ShowSearchInput: false; MaxSelection: 1; }
              $C.@TextField #NodeInput { @Anchor = (Left: 0, Top: 44, Width: 380, Height: 36); }
            }

            Group #NodeButtons {
              Anchor: (Height: 38, Bottom: 12);
              LayoutMode: Left;
              $C.@TextButton #AddNodeButton { @Anchor = (Width: 128, Right: 8); Text: "Add Node"; }
              $C.@CancelTextButton #RemoveNodeButton { @Anchor = (Width: 150); Text: "Remove Node"; }
            }

            Label #NodeRow0 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow1 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow2 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow3 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow4 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow5 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow6 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
            Label #NodeRow7 { Anchor: (Height: 28, Bottom: 3); Text: ""; Visible: false; Style: (FontSize: 13, TextColor: #ffffff, VerticalAlignment: Center); }
          }

          Group #MemberPane {
            FlexWeight: 1;
            LayoutMode: Top;
            Padding: (Left: 12);

            @SectionTitle { Text: "Members"; }
            @FieldLabel { Text: "Player, Known Username, or UUID"; }
            $C.@TextField #MemberInput { @Anchor = (Height: 36, Bottom: 8); }

            Group #MemberButtons {
              Anchor: (Height: 38, Bottom: 12);
              LayoutMode: Left;
              $C.@TextButton #AddMemberButton { @Anchor = (Width: 150, Right: 8); Text: "Add Member"; }
              $C.@CancelTextButton #RemoveMemberButton { @Anchor = (Width: 170); Text: "Remove Member"; }
            }

            $C.@TextButton #MemberRow0 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow1 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow2 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow3 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow4 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow5 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow6 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
            $C.@TextButton #MemberRow7 { @Anchor = (Height: 30, Bottom: 3); Text: ""; Visible: false; }
          }
        }

        Group #Actions {
          Anchor: (Height: 46, Top: 14);
          LayoutMode: Right;

          Group #DefaultGroupRow {
            Anchor: (Width: 210, Height: 38, Right: 16);
            LayoutMode: Left;

            $C.@CheckBox #DefaultGroupCheck {
              Anchor: (Width: 24, Height: 24, Right: 10);
            }

            Label {
              FlexWeight: 1;
              Text: "Default group";
              Style: (FontSize: 14, TextColor: #ffffff, VerticalAlignment: Center);
            }
          }

          $C.@CancelTextButton #DeleteGroupButton {
            @Anchor = (Width: 170);
            Text: "Delete Group";
          }
        }
      }
    }
  }
}
